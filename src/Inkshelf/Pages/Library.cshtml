@page
@model Inkshelf.Pages.LibraryModel
@{
    Response.Headers["Cache-Control"] = "no-store";
    if (Model.AnyConverting) { ViewData["MetaRefresh"] = 30; }
}

<div class="page-head" id="top">
    <h1 class="page-title">
        <a href="/?all=1" class="home-link" title="Libraries"><img src="~/img/icon-black.png" alt="" class="title-icon" /></a>
        <a href="/?all=1">Libraries</a> <span class="crumb-sep">›</span> @Model.LibraryName
    </h1>
    <form class="fav-form" method="post" action="/favorite">
        @Html.AntiForgeryToken()
        <input type="hidden" name="libraryId" value="@Model.Id" />
        <button type="submit" class="fav-star" title="@(Model.IsFavorite ? "Unset favorite" : "Set favorite")">@(Model.IsFavorite ? "★" : "☆")</button>
    </form>
    <form class="searchbar" method="get" action="/library/@Model.Id">
        <input type="search" name="q" value="@Model.Q" placeholder="Search…" />
        <button type="submit">Search</button>
    </form>
    <a class="settings-link" href="/settings" title="Settings"><img src="~/img/gear-black.png" alt="Settings" class="settings-icon" width="24" height="24" /></a>
</div>

@if (Model.IsSearch)
{
    var books = Model.SearchResults?.Book ?? new();
    var series = Model.SearchResults?.Series ?? new();
    var authors = Model.SearchResults?.Authors ?? new();
    <p>Results for "<strong>@Model.Q</strong>" · <a href="/library/@Model.Id">clear</a></p>
    <nav class="tabs">
        @if (books.Count > 0) { <a href="#books">Books (@books.Count)</a> } else { <span>Books (0)</span> }
        <span class="crumb-sep">·</span>
        @if (series.Count > 0) { <a href="#series">Series (@series.Count)</a> } else { <span>Series (0)</span> }
        <span class="crumb-sep">·</span>
        @if (authors.Count > 0) { <a href="#authors">Authors (@authors.Count)</a> } else { <span>Authors (0)</span> }
    </nav>
    if (books.Count == 0 && series.Count == 0 && authors.Count == 0)
    {
        <p>No matches.</p>
    }
    if (books.Count > 0)
    {
        <h2 id="books">Books <a class="totop" href="#top">↑</a></h2>
        foreach (var b in books)
        {
            <partial name="_ItemRow" model="Model.RowFor(b.LibraryItem)" />
        }
    }
    if (series.Count > 0)
    {
        <h2 id="series">Series <a class="totop" href="#top">↑</a></h2>
        <ul>
            @foreach (var s in series)
            {
                <li><a href="@Model.Links.FilterHref("series", s.Series.Id)">@s.Series.Name</a></li>
            }
        </ul>
    }
    if (authors.Count > 0)
    {
        <h2 id="authors">Authors <a class="totop" href="#top">↑</a></h2>
        <ul>
            @foreach (var a in authors)
            {
                <li><a href="@Model.Links.FilterHref("authors", a.Id)">@a.Name</a></li>
            }
        </ul>
    }
}
else
{
    if (Model.IsFiltered)
    {
        <p>Filtered by <strong>@Model.FilterDisplay</strong> · <a href="/library/@Model.Id">clear</a></p>
    }
    <nav class="sortbar">
        Sort:
        <a href="@Model.Links.SortHref("media.metadata.title")">Title@(Inkshelf.Pages.SortLinks.Arrow("media.metadata.title", Model.Sort, Model.Desc))</a> ·
        <a href="@Model.Links.SortHref("media.metadata.authorNameLF")">Author@(Inkshelf.Pages.SortLinks.Arrow("media.metadata.authorNameLF", Model.Sort, Model.Desc))</a> ·
        <a href="@Model.Links.SortHref("addedAt")">Added@(Inkshelf.Pages.SortLinks.Arrow("addedAt", Model.Sort, Model.Desc))</a>
        @if (!string.IsNullOrEmpty(Model.Series) || Model.Filter?.StartsWith("series.") == true)
        {
            <text> · </text><a href="@Model.Links.SortHref("sequence")">Sequence@(Inkshelf.Pages.SortLinks.Arrow("sequence", Model.Sort, Model.Desc))</a>
        }
    </nav>
    <partial name="_Pager" model="Model" />
    @if (Model.Items.Count == 0)
    {
        <p>No items.</p>
    }
    @foreach (var item in Model.Items)
    {
        <partial name="_ItemRow" model="Model.RowFor(item)" />
    }
    @if (Model.Items.Count > 0)
    {
        <partial name="_Pager" model="Model" />
    }
}
