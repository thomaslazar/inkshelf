@page
@model Inkshelf.Pages.LibraryModel
@{ ViewData["LibraryId"] = Model.Id; }
@section topbar {
    <form class="searchbar" method="get" action="/library/@Model.Id">
        <input type="search" name="q" value="@Model.Q" placeholder="Search…" />
        <button type="submit">Search</button>
    </form>
}

<div class="page-head">
    <h1 class="page-title">
        <img src="~/img/icon-black.png" alt="" class="title-icon" />
        <a href="/?all=1">Libraries</a> <span class="crumb-sep">›</span> @Model.LibraryName
    </h1>
    <form class="fav-form" method="post" action="/favorite">
        @Html.AntiForgeryToken()
        <input type="hidden" name="libraryId" value="@Model.Id" />
        <button type="submit" class="fav-star" title="@(Model.IsFavorite ? "Unset favorite" : "Set favorite")">@(Model.IsFavorite ? "★" : "☆")</button>
    </form>
</div>

@if (Model.IsSearch)
{
    <p>Results for "<strong>@Model.Q</strong>" · <a href="/library/@Model.Id">clear</a></p>
    var books = Model.SearchResults?.Book ?? new();
    var series = Model.SearchResults?.Series ?? new();
    var authors = Model.SearchResults?.Authors ?? new();
    if (books.Count == 0 && series.Count == 0 && authors.Count == 0)
    {
        <p>No matches.</p>
    }
    if (books.Count > 0)
    {
        <h2>Books</h2>
        foreach (var b in books)
        {
            <partial name="_ItemRow" model="b.LibraryItem" />
        }
    }
    if (series.Count > 0)
    {
        <h2>Series</h2>
        <ul>
            @foreach (var s in series)
            {
                <li><a href="@Model.SeriesFilterHref(s.Series.Id)">@s.Series.Name</a></li>
            }
        </ul>
    }
    if (authors.Count > 0)
    {
        <h2>Authors</h2>
        <ul>
            @foreach (var a in authors)
            {
                <li><a href="@Model.AuthorFilterHref(a.Id)">@a.Name</a></li>
            }
        </ul>
    }
}
else
{
    if (Model.IsFiltered)
    {
        <p>Filtered by <strong>@Model.FilterLabel</strong> · <a href="/library/@Model.Id">clear</a></p>
    }
    string carry(string k, string? v) => string.IsNullOrEmpty(v) ? "" : $"&{k}={System.Uri.EscapeDataString(v)}";
    var filterQs = carry("filter", Model.Filter) + carry("author", Model.Author) + carry("series", Model.Series);
    <nav class="pager">
        @if (Model.Pager.HasPrev)
        {
            <a href="/library/@Model.Id?page=@(Model.Pager.DisplayPage - 1)@filterQs">&larr; Prev</a>
        }
        <span>Page @Model.Pager.DisplayPage of @Math.Max(1, Model.Pager.TotalPages)</span>
        @if (Model.Pager.HasNext)
        {
            <a href="/library/@Model.Id?page=@(Model.Pager.DisplayPage + 1)@filterQs">Next &rarr;</a>
        }
    </nav>
    @if (Model.Items.Count == 0)
    {
        <p>No items.</p>
    }
    @foreach (var item in Model.Items)
    {
        <partial name="_ItemRow" model="item" />
    }
}
