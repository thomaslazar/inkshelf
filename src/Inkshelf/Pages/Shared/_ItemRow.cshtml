@model Inkshelf.Abs.AbsItem
@{
    var libId = ViewData["LibraryId"] as string ?? "";
    var m = Model.Media?.Metadata;
    string AuthorHref(string id) => $"/library/{libId}?filter={System.Uri.EscapeDataString(Inkshelf.Abs.AbsFilter.Encode("authors", id))}";
    string SeriesHref(string id) => $"/library/{libId}?filter={System.Uri.EscapeDataString(Inkshelf.Abs.AbsFilter.Encode("series", id))}";
}
<div class="item">
    <img src="/cover/@Model.Id?w=120" alt="" width="60" />
    <div>
        <strong>@(m?.Title ?? "(untitled)")</strong><br />
        @if (m?.Authors is { Count: > 0 })
        {
            @for (var i = 0; i < m.Authors.Count; i++)
            {
                if (i > 0) { <text>, </text> }
                <a href="@AuthorHref(m.Authors[i].Id)">@m.Authors[i].Name</a>
            }
        }
        @if (m?.Series is { Count: > 0 })
        {
            foreach (var s in m.Series)
            {
                <text> · </text>
                <a href="@SeriesHref(s.Id)">@s.Name@(string.IsNullOrEmpty(s.Sequence) ? "" : $" #{s.Sequence}")</a>
            }
        }
    </div>
</div>
