@model Inkshelf.Pages.ItemRowModel
@{
    var item = Model.Item;
    var m = item.Media?.Metadata;
    // Listing rows are enriched with structured authors/series arrays (with ids)
    // via the batch call; search rows carry only the comma-joined name strings.
    // Prefer the arrays: they separate multiple authors/series correctly and never
    // mistake a comma inside one name for a separator.
}
<div class="item">
    <a class="cover-link" href="/item/@item.Id">
    @if (!string.IsNullOrEmpty(item.Media?.CoverPath))
    {
        <span class="cover"><img src="/cover/@item.Id?w=120" alt="" /></span>
    }
    else
    {
        <span class="cover placeholder">@(string.IsNullOrEmpty(m?.Title) ? "?" : m!.Title!.Substring(0, 1).ToUpperInvariant())</span>
    }
    </a>
    <div class="body">
        <a href="/item/@item.Id"><strong>@(m?.Title ?? L["(untitled)"])</strong></a><br />
        @if (Model.Authors is { Count: > 0 } authors)
        {
            for (var i = 0; i < authors.Count; i++)
            {
                if (i > 0) { <text>, </text> }
                <a href="@Model.Links.FilterHref("authors", authors[i].Id)">@authors[i].Name</a>
            }
        }
        else if (!string.IsNullOrWhiteSpace(m?.AuthorName))
        {
            <a href="@Model.Links.AuthorHref(m!.AuthorName!)">@m!.AuthorName!</a>
        }
        @if (Model.Series is { Count: > 0 } series)
        {
            foreach (var s in series)
            {
                <text> · </text>
                <a href="@Model.Links.FilterHref("series", s.Id)">@s.Name@(string.IsNullOrEmpty(s.Sequence) ? "" : $" #{s.Sequence}")</a>
            }
        }
        else if (!string.IsNullOrWhiteSpace(m?.SeriesName))
        {
            <text> · </text>
            <a href="@Model.Links.SeriesHref(m!.SeriesName!)">@m!.SeriesName!</a>
        }
    </div>
    @{ var fmt = item.Media?.EbookFormat ?? item.Media?.EbookFile?.EbookFormat; }
    @if (!string.IsNullOrEmpty(fmt))
    {
        <div class="actions">
            <a href="/download/@item.Id">@L["Download"]</a>
            @if (Model.State != ConvertRowState.NotConvertible)
            {
                <partial name="_ConvertAction" model="new Inkshelf.Pages.ConvertActionModel(item.Id, null, Model.State, Model.ReturnUrl)" />
            }
            <form class="read-form" method="post" action="/read/@item.Id">
                @Html.AntiForgeryToken()
                <input type="hidden" name="read" value="@(Model.Read ? "0" : "1")" />
                <input type="hidden" name="return" value="@Model.ReturnUrl" />
                @if (Model.Read)
                {
                    <button type="submit" class="read-btn" title="@L["Mark as unread"]">&#10003; @L["Read"]</button>
                }
                else
                {
                    <button type="submit" class="read-btn" title="@L["Mark as read"]">@L["Mark read"]</button>
                }
            </form>
        </div>
    }
</div>
