@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Inkshelf</title>
    <link rel="stylesheet" href="~/app.css" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="~/favicon-16x16.png" />
    <link rel="icon" href="~/favicon.ico" />
    <link rel="apple-touch-icon" href="~/apple-touch-icon.png" />
    <link rel="manifest" href="~/site.webmanifest" />
    <meta name="theme-color" content="#ffffff" />
</head>
<body>
    <main>
        @RenderBody()
    </main>
    <script>
    /* Near-zero JS: report the device's physical screen size (CSS px × DPR) in a
       cookie so /convert can downscale comic pages to this device (comics differ
       per Tolino model). ES5 + try/catch so old e-reader browsers stay happy. */
    (function () {
        try {
            var d = window.devicePixelRatio || 1;
            if (screen.width && screen.height) {
                document.cookie = "scr=" + screen.width + "x" + screen.height + "x" + d + ";path=/;max-age=31536000";
            }
        } catch (e) {}
    })();
    </script>
</body>
</html>
